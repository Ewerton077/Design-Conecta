@{
    ViewData["Title"] = "Painel do Professor";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EduSys — Professor</title>
    <link rel="stylesheet" href="~/css/geral.css" />
    <style>
        body { background: linear-gradient(165deg, #051211 0%, #0B2B28 50%, #051211 100%); }

        .dash-page { min-height: 100vh; display: flex; }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
        }

        .page-title    { font-size: 24px; font-weight: 700; color: var(--text-100); line-height: 1.2; }
        .page-title span { color: var(--lime-300); }
        .page-subtitle { font-size: 13px; color: var(--text-600); margin-top: 4px; }

        .topbar-actions { display: flex; gap: 10px; align-items: center; }

        /* Grids */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
            margin-bottom: 16px;
        }

        .content-row {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 14px;
            margin-bottom: 14px;
        }

        /* Turma count */
        .turma-count {
            font-family: var(--font-mono);
            font-size: 15px;
            color: var(--text-600);
            flex-shrink: 0;
        }

        /* Agenda time */
        .agenda-time {
            font-family: var(--font-mono);
            font-size: 11px;
            color: var(--teal-400);
            min-width: 40px;
            flex-shrink: 0;
        }

        /* Comunicado */
        .comunicado-item {
            padding: 13px;
            border-radius: var(--radius-md);
            background: var(--bg-row);
            border: 1px solid var(--border);
            transition: border-color 0.2s;
        }
        .comunicado-item:hover { border-color: var(--border-strong); }

        /* Tabela cores */
        .media-green  { font-family: var(--font-mono); font-weight: 700; color: var(--lime-400); }
        .media-yellow { font-family: var(--font-mono); font-weight: 700; color: #ffd93d; }
        .media-red    { font-family: var(--font-mono); font-weight: 700; color: #ff6060; }

        .freq-row      { display: flex; align-items: center; gap: 10px; }
        .freq-bar-wrap { width: 72px; }

        /* glow */
        .glow-prof {
            width: 600px; height: 500px;
            bottom: -150px; left: 10%;
            background: radial-gradient(ellipse, rgba(74,139,130,0.07) 0%, transparent 70%);
        }
    </style>
</head>
<body>
<div class="dash-page">

    <div class="glow-blob glow-prof"></div>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="navbar-logo-icon">
                <svg viewBox="0 0 18 18" fill="none">
                    <rect x="1" y="1" width="6" height="6" rx="1" stroke="#76C057" stroke-width="1.5"/>
                    <rect x="11" y="1" width="6" height="6" rx="1" stroke="#76C057" stroke-width="1.5"/>
                    <rect x="1" y="11" width="6" height="6" rx="1" stroke="#76C057" stroke-width="1.5"/>
                    <rect x="11" y="11" width="6" height="6" rx="1" stroke="#A8D582" stroke-width="1.5" opacity=".55"/>
                </svg>
            </div>
            <span class="navbar-brand-text">EDU<span>SYS</span></span>
        </div>

        <p class="sidebar-section">Menu</p>

        <a class="nav-link active" asp-controller="Professor" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <rect x="3" y="3" width="7" height="7" rx="1.5"/>
                <rect x="14" y="3" width="7" height="7" rx="1.5"/>
                <rect x="3" y="14" width="7" height="7" rx="1.5"/>
                <rect x="14" y="14" width="7" height="7" rx="1.5"/>
            </svg>
            Dashboard
        </a>
        <a class="nav-link" href="#">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
            </svg>
            Turmas
        </a>
        <a class="nav-link" href="#">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M9 11l3 3L22 4"/>
                <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
            </svg>
            Avaliações
        </a>
        <a class="nav-link" href="#">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <path d="M16 2v4M8 2v4M3 10h18"/>
            </svg>
            Agenda
        </a>
        <a class="nav-link" href="#">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
            </svg>
            Comunicados
        </a>

        <div class="sidebar-spacer"></div>
        <p class="sidebar-section">Conta</p>

        <a class="nav-link" href="#">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <circle cx="12" cy="8" r="4"/>
                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
            </svg>
            Perfil
        </a>
        <a class="nav-link" asp-controller="Home" asp-action="Index">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/>
            </svg>
            Sair
        </a>

        <div class="sidebar-footer">
            <div class="user-chip">
                <div class="avatar" style="width:32px;height:32px;font-size:11px;background:linear-gradient(135deg,#4A8B82 0%,#0B2B28 100%)">CM</div>
                <div>
                    <p class="user-chip-name">Carlos Mendes</p>
                    <p class="user-chip-role">PROFESSOR</p>
                </div>
            </div>
        </div>
    </aside>

    <!-- MAIN -->
    <main class="main-content anim-1">

        <div class="topbar">
            <div>
                <h1 class="page-title">Painel <span>Professor</span></h1>
                <p class="page-subtitle">Gerencie turmas, notas e frequência</p>
            </div>
            <div class="topbar-actions">
                <button class="btn btn-outline">EXPORTAR_</button>
                <button class="btn btn-primary">+ NOVA TAREFA</button>
            </div>
        </div>

        <!-- Stats -->
        <div class="stats-row anim-2">
            <div class="stat-card">
                <span class="label">Alunos Ativos</span>
                <p class="stat-value">20</p>
                <p class="stat-sub">semestre 2025.1</p>
            </div>
            <div class="stat-card">
                <span class="label">Total Alunos</span>
                <p class="stat-value">80</p>
                <p class="stat-sub">em todas as turmas</p>
            </div>
            <div class="stat-card">
                <span class="label">Média Geral</span>
                <p class="stat-value">7.8</p>
                <p class="stat-sub">das turmas</p>
            </div>
            <div class="stat-card">
                <span class="label">Pendências</span>
                <p class="stat-value" style="color:#ff6060;">5</p>
                <p class="stat-sub">apresentações</p>
            </div>
        </div>

        <!-- Turmas + Agenda + Comunicados -->
        <div class="content-row anim-3">

            <!-- Turmas -->
            <div class="card">
                <div class="card-header">
                    <span class="label-green">Minhas Turmas</span>
                    <span class="badge badge-teal">4 ATIVAS</span>
                </div>
                <div style="display:flex;flex-direction:column;gap:8px;">
                    <div class="list-item">
                        
                        <div style="flex:1;min-width:0">
                            <p class="text-sm text-medium truncate">Turma 1</p>
                            <p class="text-xs text-muted mt-1">Dados: 17 | Empregados: 12</p>
                        </div>
                        <span class="turma-count">20</span>
                    </div>
                    <div class="list-item">
                        <!--TAG SPAN ATRAS PARA ALGUM DETALHAMENTO DE INFORMAÇÕES-->
                        <div style="flex:1;min-width:0">
                            <p class="text-sm text-medium truncate">Turma 2</p>
                            <p class="text-xs text-muted mt-1">Dados: 17 | Empregados: 12</p>
                        </div>
                        <span class="turma-count">20</span>
                    </div>
                    <div class="list-item">
                        
                        <div style="flex:1;min-width:0">
                            <p class="text-sm text-medium truncate">Turma 3</p>
                            <p class="text-xs text-muted mt-1">Dados: 17 | Empregados: 12</p>
                        </div>
                        <span class="turma-count">18</span>
                    </div>
                    <div class="list-item">
                       
                        <div style="flex:1;min-width:0">
                            <p class="text-sm text-medium truncate">Turma 4</p>
                            <p class="text-xs text-muted mt-1">Dados: 17 | Empregados: 12</p>
                        </div>
                        <span class="turma-count">20</span>
                    </div>
                </div>
            </div>

            <!-- Agenda -->
            <div class="card">
                <div class="card-header">
                    <span class="label-green">Agenda de Hoje</span>
                    <span class="badge badge-neutral">MÊS · DIA</span>
                </div>
                <div style="display:flex;flex-direction:column;gap:8px;">
                    <div class="list-item">
                        <span class="agenda-time">08h00</span>
                        <div style="flex:1;min-width:0">
                            <p class="text-sm text-medium truncate">Reunião de Negócios</p>
                            <p class="text-xs text-muted mt-1">Clean Architecture</p>
                        </div>
                        <span class="agenda-tag agenda-tag-green">AULA</span>
                    </div>
                    <div class="list-item">
                        <span class="agenda-time">10h00</span>
                        <div style="flex:1;min-width:0">
                            <p class="text-sm text-medium truncate">Material Aula Tech</p>
                            <p class="text-xs text-muted mt-1">Aula Prática</p>
                        </div>
                        <span class="agenda-tag agenda-tag-green">AULA</span>
                    </div>
                    <div class="list-item">
                        <span class="agenda-time">13h30</span>
                        <div style="flex:1;min-width:0">
                            <p class="text-sm text-medium truncate">Apresentação de Projeto</p>
                            <p class="text-xs text-muted mt-1">Ideia de projeto para alunos</p>
                        </div>
                        <span class="agenda-tag agenda-tag-neutral">RNO</span>
                    </div>
                    <div class="list-item">
                        <span class="agenda-time">16h00</span>
                        <div style="flex:1;min-width:0">
                            <p class="text-sm text-medium truncate">Relatório de Projeto</p>
                            <p class="text-xs text-muted mt-1">Descrição inicial</p>
                        </div>
                        <span class="agenda-tag agenda-tag-red">REQUIRED</span>
                    </div>
                </div>
            </div>

            <!-- Comunicados -->
            <div class="card">
                <div class="card-header">
                    <span class="label-green">Comunicados</span>
                </div>
                <div style="display:flex;flex-direction:column;gap:8px;">
                    <div class="comunicado-item">
                        <p class="label mb-1">MATHEUS · MPK</p>
                        <p class="text-sm text-medium">Atualização de currículo</p>
                        <p class="text-xs text-muted mt-1">Sexta-feira · 10h00</p>
                    </div>
                    <div class="comunicado-item">
                        <p class="label mb-1">JOÃO FANTIN</p>
                        <p class="text-sm text-medium">Atualização de criptografia</p>
                        <p class="text-xs text-muted mt-1">15/12 · Via sistema</p>
                    </div>
                    <div class="comunicado-item">
                        <p class="label mb-1">GALLO</p>
                        <p class="text-sm text-medium">Material enviado 12h00</p>
                        <p class="text-xs text-muted mt-1">07 a 11/04 · Conecta</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabela alunos -->
        <div class="card anim-4">
            <div class="card-header">
                <span class="label-green">Desempenho dos Alunos · ES-301</span>
                <div style="display:flex;gap:8px;">
                    <button class="btn btn-outline" style="padding:7px 14px;font-size:9px;">Ver Alunos</button>
                    <button class="btn btn-outline" style="padding:7px 14px;font-size:9px;">Lançar Notas</button>
                    <button class="btn btn-outline" style="padding:7px 14px;font-size:9px;color:var(--lime-300);border-color:rgba(118,192,87,0.2);">Relatórios</button>
                </div>
            </div>
            <div style="overflow-x:auto;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="padding-left:6px;"></th>
                            <th>Nome</th>
                            <th>RA</th>
                            <th>Média</th>
                            <th>Frequência</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="padding-left:6px;"><div class="avatar avatar-sm">JF</div></td>
                            <td class="text-sm">João Fantin</td>
                            <td class="label">2021004892</td>
                            <td><span class="media-green">8.4</span></td>
                            <td>
                                <div class="freq-row">
                                    <div class="freq-bar-wrap">
                                        <div class="progress-track"><div class="progress-fill" style="width:87%"></div></div>
                                    </div>
                                    <span class="label">87%</span>
                                </div>
                            </td>
                            <td><span class="badge">APROVADO</span></td>
                        </tr>
                        <tr>
                            <td style="padding-left:6px;"><div class="avatar avatar-sm" style="background:linear-gradient(135deg,#4A8B82,#1B4D46)">AC</div></td>
                            <td class="text-sm">Ana Clara</td>
                            <td class="label">2022001123</td>
                            <td><span class="media-green">9.1</span></td>
                            <td>
                                <div class="freq-row">
                                    <div class="freq-bar-wrap">
                                        <div class="progress-track"><div class="progress-fill" style="width:95%"></div></div>
                                    </div>
                                    <span class="label">95%</span>
                                </div>
                            </td>
                            <td><span class="badge">APROVADO</span></td>
                        </tr>
                        <tr>
                            <td style="padding-left:6px;"><div class="avatar avatar-sm" style="background:linear-gradient(135deg,#ffe066,#665800)">VI</div></td>
                            <td class="text-sm">Vinícius</td>
                            <td class="label">2020009871</td>
                            <td><span class="media-yellow">5.8</span></td>
                            <td>
                                <div class="freq-row">
                                    <div class="freq-bar-wrap">
                                        <div class="progress-track">
                                            <div class="progress-fill" style="width:62%;background:#ffd93d;box-shadow:none;"></div>
                                        </div>
                                    </div>
                                    <span class="label">62%</span>
                                </div>
                            </td>
                            <td><span class="badge badge-yellow">RISCO</span></td>
                        </tr>
                        <tr>
                            <td style="padding-left:6px;"><div class="avatar avatar-sm" style="background:linear-gradient(135deg,#ff6060,#660000)">PS</div></td>
                            <td class="text-sm">Pedro Soto</td>
                            <td class="label">2023000456</td>
                            <td><span class="media-red">3.2</span></td>
                            <td>
                                <div class="freq-row">
                                    <div class="freq-bar-wrap">
                                        <div class="progress-track">
                                            <div class="progress-fill" style="width:48%;background:#ff6060;box-shadow:none;"></div>
                                        </div>
                                    </div>
                                    <span class="label">48%</span>
                                </div>
                            </td>
                            <td><span class="badge badge-red">REPROVADO</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer-bar">
            <div style="display:flex;align-items:center;gap:8px;">
                <span class="status-dot"></span>
                <span class="label">EDUSYS · 2025 · TODOS OS DIREITOS RESERVADOS</span>
            </div>
            <span class="label">v2.4.1</span>
        </div>

    </main>
</div>
</body>
</html>
