@{
    ViewData["Title"] = "Home";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Barracred Conecta</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        /* ── VARIÁVEIS DE CORES (tema claro) ── */
   


        :root {
            --brand-lime:        #1EB53A;
            --brand-lime-dark:   #008744;
            --brand-lime-light:  #31f301;
            --brand-green:       #1EB53A;
            --brand-green-mid:   #008744;
            --brand-green-dark:  #004438;
            --brand-teal:        #08785B;
            --brand-cyan:        #07A5BF;
            --brand-blue:        #316BA5;
            --brand-orange:      #FF6600;
            --brand-yellow:      #FFC000;

            --bg:                #FFFFFF;
            --bg-section:        #F4F9F8;
            --bg-section-alt:    #EAEFED;
            --bg-card:           #FFFFFF;
            --bg-hero-overlay:   rgba(0, 68, 56, 0.78);

            --text-100:          #1a2e28;
            --text-200:          #213d35;
            --text-400:          #3a5a50;
            --text-600:          #5c7a71;
            --text-800:          #8aada4;

            --border:            rgba(8, 120, 91, 0.18);
            --border-hover:      rgba(161, 188, 33, 0.6);
            --border-card:       rgba(8, 120, 91, 0.22);

            --shadow-sm:         0 2px 8px rgba(0,68,56,0.08);
            --shadow-md:         0 4px 20px rgba(0,68,56,0.12);

            --radius-sm:         4px;
            --radius-md:         8px;
            --radius-lg:         12px;
            --radius-xl:         16px;
            --radius-full:       9999px;

            --font-sans:         'Segoe UI', system-ui, sans-serif;
            --font-mono:         'SF Mono', 'Fira Code', monospace;
        }

        /* ── RESET / BASE ── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            color: var(--text-200);
            font-family: var(--font-sans);
            overflow-x: hidden;
        }

/* ── HEADER ── */
.header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(1.3px);
    -webkit-backdrop-filter: blur(1.3px);
    border-bottom: 1px solid transparent;
    transition: box-shadow 0.3s, background 0.3s;
}
.header.scrolled {
    background: rgba(0, 0, 0, 0.445);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.199);
    border-bottom: 1px solid rgba(161,188,33,0.3);
}

.navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
}
        .navbar-brand-text {
            font-family: var(--font-mono);
            font-size: 16px;
            letter-spacing: 0.1em;
            color: #ffffff;
            text-decoration: none;
        }
        .navbar-brand-text span { color: var(--brand-lime); }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 2rem;
            align-items: center;
        }
        .nav-links a {
            text-decoration: none;
            color: rgba(255,255,255,0.75);
            font-size: 0.9rem;
            font-weight: 500;
            transition: color 0.2s;
            position: relative;
        }
        .nav-links a:hover { color: var(--brand-lime); }
        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -2px; left: 0;
            width: 0; height: 2px;
            background: var(--brand-lime);
            transition: width 0.3s;
        }
        .nav-links a:hover::after { width: 100%; }

        .btn-aluno {
            background: rgba(161,188,33,0.18) !important;
            color: var(--brand-lime) !important;
            border: 1px solid rgba(161,188,33,0.5);
            padding: 0.5rem 1.5rem;
            border-radius: var(--radius-full);
            font-family: var(--font-mono);
            font-size: 11px;
            letter-spacing: 0.18em;
            transition: background 0.2s, color 0.2s;
        }
        .btn-aluno:hover {
            background: rgba(161,188,33,0.32) !important;
            color: #ffffff !important;
        }

        .theme-toggle {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            color: rgba(255,255,255,0.6);
            padding: 0.5rem;
            transition: color 0.2s;
        }
        .theme-toggle:hover { color: var(--brand-lime); }

        .menu-toggle {
            display: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: rgba(255,255,255,0.75);
            background: none;
            border: none;
        }

        /* ── HERO ── */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 8rem 2rem 4rem;
            position: relative;
            background-size: cover;
            background-position: center;
            overflow: hidden;
        }
        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(0, 0, 0, 0.82) 0%, rgba(0, 0, 0, 0.78) 100%);
            z-index: 1;
        }
        .hero-content {
            max-width: 900px;
            text-align: center;
            position: relative;
            z-index: 3;
        }
        .hero-badge {
            display: inline-block;
            background: rgba(161,188,33,0.15);
            color: var(--brand-lime);
            border: 1px solid rgba(161,188,33,0.4);
            padding: 6px 18px;
            border-radius: var(--radius-full);
            font-family: var(--font-mono);
            font-size: 10px;
            letter-spacing: 0.18em;
            margin-bottom: 1.5rem;
            animation: fadeUp 0.8s ease-out;
        }
        .hero h1 {
            font-size: 4rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: var(--brand-lime);
            animation: fadeUp 0.8s ease-out 0.2s backwards;
        }
        .hero h1 span { color: #ffffff; }
        .hero h2 {
            font-size: 1.3rem;
            font-weight: 400;
            color: rgba(255,255,255,0.8);
            margin-bottom: 1.5rem;
            animation: fadeUp 0.8s ease-out 0.4s backwards;
        }
        .hero p {
            font-size: 1rem;
            color: rgba(255,255,255,0.7);
            margin-bottom: 1rem;
            max-width: 680px;
            margin-left: auto;
            margin-right: auto;
            animation: fadeUp 0.8s ease-out 0.6s backwards;
        }
        .hero .destaque {
            font-size: 1rem;
            font-weight: 600;
            color: var(--brand-lime);
            margin: 1.5rem 0;
            animation: fadeUp 0.8s ease-out 0.8s backwards;
        }
        .hero-btns {
            display: flex;
            gap: 1rem;
            justify-content: center;
            margin-top: 2rem;
            animation: fadeUp 0.8s ease-out 1s backwards;
        }
        .hero .btn-primary-hero {
            background: linear-gradient(135deg, var(--brand-lime) 0%, var(--brand-lime-dark) 100%);
            color: #2a3d00;
            padding: 12px 28px;
            border-radius: var(--radius-md);
            font-family: var(--font-mono);
            font-size: 11px;
            letter-spacing: 0.18em;
            font-weight: 700;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            box-shadow: 0 4px 18px rgba(161,188,33,0.35);
            transition: all 0.22s;
        }
        .hero .btn-primary-hero:hover {
            background: linear-gradient(135deg, var(--brand-lime-light) 0%, var(--brand-lime) 100%);
            box-shadow: 0 6px 24px rgba(161,188,33,0.5);
            transform: translateY(-2px);
        }
        .hero .btn-secondary-hero {
            background: transparent;
            color: #ffffff;
            border: 1px solid rgba(255,255,255,0.55);
            padding: 12px 28px;
            border-radius: var(--radius-md);
            font-family: var(--font-mono);
            font-size: 11px;
            letter-spacing: 0.14em;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            transition: all 0.22s;
        }
        .hero .btn-secondary-hero:hover {
            background: rgba(255,255,255,0.1);
            border-color: rgba(255,255,255,0.85);
        }

        .decorative-line {
            position: absolute;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(161,188,33,0.4), transparent);
            pointer-events: none;
            z-index: 3;
        }
        .decorative-line.top    { top: 120px; left: 10%; width: 80%; }
        .decorative-line.bottom { bottom: 100px; left: 10%; width: 60%; }

        /* ── QUICKSTATS ── */
        .bc-quickstats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1px;
            background: var(--border);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }
        .bc-quickstats-item {
            background: var(--bg-section);
            padding: 20px 24px;
            text-align: center;
            transition: background 0.2s;
        }
        .bc-quickstats-item:hover { background: #dff0ea; }
        .bc-quickstats-num {
            font-family: var(--font-mono);
            font-size: 28px;
            font-weight: 700;
            color: var(--brand-green-mid);
            line-height: 1;
            margin-bottom: 4px;
        }
        .bc-quickstats-label {
            font-family: var(--font-mono);
            font-size: 10px;
            letter-spacing: 0.16em;
            text-transform: uppercase;
            color: var(--text-600);
        }

        /* ── SEÇÕES GENÉRICAS ── */
        .section { padding: 5rem 2rem; position: relative; z-index: 1; }
        .container { max-width: 1200px; margin: 0 auto; }

        .section-title {
            font-size: 2rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 0.75rem;
            color: var(--brand-green-mid);
        }
        .section-title::after {
            content: '';
            display: block;
            width: 36px; height: 2px;
            background: linear-gradient(90deg, var(--brand-lime), transparent);
            margin: 8px auto 0;
            border-radius: 2px;
        }
        .section-subtitle {
            text-align: center;
            font-size: 0.95rem;
            color: var(--text-600);
            max-width: 800px;
            margin: 0 auto 3rem;
        }

        /* ── SOBRE ── */
        .sobre {
            background: var(--bg-section);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }
        .sobre-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: start;
        }
        .sobre-text p { color: var(--text-600); font-size: 0.92rem; margin-bottom: 1rem; }
        .sobre-text .destaque { color: var(--brand-green-mid); font-weight: 600; font-size: 0.95rem; }
        .sobre-beneficios h3 { color: var(--text-200); font-size: 1.1rem; margin-bottom: 1rem; }
        .beneficios-list { list-style: none; }
        .beneficios-list li {
            display: flex; align-items: center; gap: 0.75rem;
            padding: 0.6rem 0;
            color: var(--text-200); font-size: 0.92rem;
            border-bottom: 1px solid var(--border);
        }
        .beneficios-list li:last-child { border-bottom: none; }
        .beneficios-list li i { color: var(--brand-green-mid); }

        /* ── CONTEÚDO ── */
        .conteudo-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
        }
        .conteudo-card {
            background: var(--bg-card);
            border: 1px solid var(--border-card);
            padding: 1.5rem;
            border-radius: var(--radius-lg);
            text-align: center;
            box-shadow: var(--shadow-sm);
            transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
            position: relative;
            overflow: hidden;
        }
        .conteudo-card:hover {
            border-color: var(--border-hover);
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
        }
        .conteudo-card i { color: var(--brand-green-mid); font-size: 2rem; margin-bottom: 1rem; display: block; }
        .conteudo-card h3 { color: var(--text-200); font-size: 1rem; margin-bottom: 0.75rem; }
        .conteudo-card p { color: var(--text-600); font-size: 0.85rem; }
        .conteudo-card::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(161,188,33,0.06), transparent);
            transition: left 0.5s;
        }
        .conteudo-card:hover::before { left: 100%; }

        /* ── POR QUÊ ── */
        .sectionporque {
            padding: 6rem 0;
            background: var(--bg-section);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }
        .sectionporque .container { position: relative; z-index: 1; }

        .missao-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
            margin-top: 3rem;
        }
        .missao-card {
            background: var(--bg-card);
            border: 1px solid var(--border-card);
            padding: 1.5rem;
            border-radius: var(--radius-lg);
            text-align: center;
            box-shadow: var(--shadow-sm);
            transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
            position: relative;
            overflow: hidden;
        }
        .missao-card:hover {
            border-color: var(--border-hover);
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
        }
        .missao-card i { color: var(--brand-lime); font-size: 1.8rem; margin-bottom: 1rem; display: block; }
        .missao-card h4 { color: var(--text-200); font-size: 1rem; margin-bottom: 0.5rem; }
        .missao-card p { color: var(--text-600); font-size: 0.85rem; }
        .missao-card::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(161,188,33,0.06), transparent);
            transition: left 0.5s;
        }
        .missao-card:hover::before { left: 100%; }

        /* ── PARTICIPAR ── */
        .participar-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
        }
        .participar-info p { color: var(--text-600); font-size: 0.95rem; margin-bottom: 1.5rem; }
        .participar-destaques { display: flex; flex-direction: column; gap: 1rem; margin: 1.5rem 0; }
        .destaque-item { display: flex; align-items: center; gap: 1rem; }
        .destaque-item i { color: var(--brand-green-mid); font-size: 1.25rem; }
        .destaque-item span { color: var(--text-200); font-size: 0.92rem; }
        .vagas-info { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1.5rem; }
        .vaga-item { display: flex; align-items: center; gap: 1rem; }
        .vaga-porcentagem {
            background: linear-gradient(135deg, var(--brand-lime) 0%, var(--brand-lime-dark) 100%);
            color: #2a3d00;
            padding: 0.4rem 1rem;
            border-radius: var(--radius-full);
            font-family: var(--font-mono);
            font-weight: 700;
            font-size: 0.95rem;
        }
        .vaga-item span { color: var(--text-200); font-size: 0.9rem; }
        .requisitos-box {
            background: var(--bg-card);
            border: 1px solid var(--border-card);
            border-radius: var(--radius-lg);
            padding: 2rem;
            box-shadow: var(--shadow-sm);
        }
        .requisitos-box h3 { color: var(--text-200); font-size: 1.1rem; margin-bottom: 1.5rem; }
        .requisitos-box ul { list-style: none; }
        .requisitos-box li {
            display: flex; align-items: flex-start; gap: 0.75rem;
            padding: 0.6rem 0;
            color: var(--text-600); font-size: 0.9rem;
            border-bottom: 1px solid var(--border);
        }
        .requisitos-box li:last-child { border-bottom: none; }
        .requisitos-box li i { color: var(--brand-green-mid); margin-top: 2px; }

        /* ── CTA ── */
        .cta-section {
            background-image: url(/css/imagens/bannerfundo.png);
            background-size: cover;        /* faz a imagem cobrir toda a área */
            background-position: center;   /* centraliza a imagem */
            background-repeat: no-repeat;  /* evita repetição */

            border-top: 1px solid rgba(161,188,33,0.25);
            border-bottom: 1px solid rgba(161,188,33,0.25);
            text-align: center;
            padding: 5rem 2rem;
            position: relative;
            z-index: 1;
}
        .cta-content h2 { color: var(--brand-lime); font-size: 2rem; margin-bottom: 1rem; }
        .cta-content p { color: rgba(255,255,255,0.75); font-size: 1rem; margin-bottom: 2rem; }
        .btn-cta {
            background: linear-gradient(135deg, var(--brand-lime) 0%, var(--brand-lime-dark) 100%);
            color: #2a3d00;
            padding: 12px 28px;
            border-radius: var(--radius-md);
            font-family: var(--font-mono);
            font-size: 11px;
            letter-spacing: 0.18em;
            font-weight: 700;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            box-shadow: 0 4px 18px rgba(161,188,33,0.35);
            transition: all 0.22s;
        }
        .btn-cta:hover {
            background: linear-gradient(135deg, var(--brand-lime-light) 0%, var(--brand-lime) 100%);
            box-shadow: 0 6px 24px rgba(161,188,33,0.5);
            transform: translateY(-2px);
        }

        /* ── EQUIPE ── */
        .equipe-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 1.5rem;
        }
        .equipe-card {
            background: var(--bg-card);
            border: 1px solid var(--border-card);
            border-radius: var(--radius-lg);
            padding: 1.25rem 0.75rem;
            text-align: center;
            box-shadow: var(--shadow-sm);
            transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
            position: relative;
            overflow: hidden;
        }
        .equipe-card:hover {
            border-color: var(--border-hover);
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
        }
        .equipe-foto img {
            width: 80px; height: 80px;
            border-radius: 50%; object-fit: cover;
            margin: 0 auto 0.75rem;
            border: 2px solid rgba(161,188,33,0.5);
            box-shadow: 0 0 12px rgba(161,188,33,0.15);
        }
        .equipe-card h4 { color: var(--text-200); font-size: 0.9rem; margin-bottom: 0.25rem; }
        .equipe-card .cargo { color: var(--brand-green-mid); font-size: 0.75rem; }
        .equipe-social { display: flex; justify-content: center; gap: 0.75rem; margin-top: 0.75rem; }
        .equipe-social a { color: var(--text-800); font-size: 1rem; transition: color 0.2s; }
        .equipe-social a:hover { color: var(--brand-green-mid); }
        .equipe-card::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(161,188,33,0.06), transparent);
            transition: left 0.5s;
        }
        .equipe-card:hover::before { left: 100%; }

        /* ── PARCEIROS ── */
        .parceiros {
            background: var(--bg-section);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }
        .parceiros-content {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
        }
        .parceiro-item {
            background: var(--bg-card);
            border: 1px solid var(--border-card);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            text-align: center;
            box-shadow: var(--shadow-sm);
            transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
            position: relative;
            overflow: hidden;
        }
        .parceiro-item:hover {
            border-color: var(--border-hover);
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }
        .parceiro-item i { color: var(--brand-green-mid); font-size: 2rem; margin-bottom: 1rem; display: block; }
        .parceiro-item h4 { color: var(--text-200); font-size: 1rem; margin-bottom: 0.5rem; }
        .parceiro-item p { color: var(--text-600); font-size: 0.85rem; }
        .parceiro-item::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(161,188,33,0.06), transparent);
            transition: left 0.5s;
        }
        .parceiro-item:hover::before { left: 100%; }

        /* ── ÁREA DO ALUNO ── */
        .area-aluno { padding: 5rem 2rem; position: relative; z-index: 1; }
        .aluno-box {
            background: var(--bg-card);
            border: 1px solid var(--border-card);
            border-radius: var(--radius-xl);
            padding: 2.5rem;
            text-align: center;
            max-width: 800px;
            margin: 0 auto;
            box-shadow: var(--shadow-md);
        }
        .aluno-box > i { color: var(--brand-green-mid); font-size: 3rem; margin-bottom: 1rem; display: block; }
        .aluno-box h2 { color: var(--brand-green-mid); font-size: 1.6rem; margin-bottom: 0.75rem; }
        .aluno-box > p { color: var(--text-600); font-size: 0.9rem; margin-bottom: 2rem; }
        .aluno-recursos {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            margin-bottom: 2rem;
        }
        .recurso-card {
            background: var(--bg-section);
            border: 1px solid var(--border-card);
            border-radius: var(--radius-md);
            padding: 1.25rem;
            text-decoration: none;
            color: var(--text-200);
            display: flex; flex-direction: column;
            align-items: center; gap: 0.75rem;
            transition: border-color 0.2s, background 0.2s;
        }
        .recurso-card:hover {
            background: #dff0ea;
            border-color: rgba(161,188,33,0.5);
        }
        .recurso-card i { color: var(--brand-green-mid); font-size: 1.6rem; }
        .recurso-card span { font-size: 0.85rem; }
        .aluno-login {
            padding-top: 1.5rem;
            border-top: 1px solid var(--border);
        }
        .aluno-login p { color: var(--text-600); font-size: 0.85rem; margin-bottom: 1rem; }
        .btn-aluno-login {
            display: inline-flex;
            align-items: center; gap: 6px;
            background: linear-gradient(135deg, var(--brand-lime) 0%, var(--brand-lime-dark) 100%);
            color: #2a3d00;
            padding: 10px 24px;
            border-radius: var(--radius-md);
            font-family: var(--font-mono);
            font-size: 11px;
            letter-spacing: 0.16em;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.22s;
            box-shadow: 0 4px 16px rgba(161,188,33,0.25);
        }
        .btn-aluno-login:hover {
            background: linear-gradient(135deg, var(--brand-lime-light) 0%, var(--brand-lime) 100%);
            transform: translateY(-1px);
        }

        /* ── TURMA (banner / gallery) ── */
        .turma-banner {
            position: relative;
            min-height: 400px;
            display: flex; align-items: center; justify-content: center;
            overflow: hidden;
        }
        .turma-banner-bg { position: absolute; inset: 0; }
        .turma-banner-bg img { width: 100%; height: 100%; object-fit: cover; }
        .turma-banner-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(135deg, rgba(0,68,56,0.88) 0%, rgba(8,120,91,0.85) 100%);
        }
        .turma-banner-content {
            position: relative; z-index: 1;
            text-align: center; color: white; padding: 2rem;
        }
        .turma-banner-content h2 { font-size: 2rem; margin-bottom: 1rem; color: #ffffff; }
        .turma-banner-content p { font-size: 1rem; color: rgba(255,255,255,0.82); margin-bottom: 2rem; }
        .turma-banner-stats { display: flex; gap: 3rem; justify-content: center; flex-wrap: wrap; }
        .banner-stat { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
        .banner-stat i { font-size: 1.75rem; color: var(--brand-lime); }
        .banner-stat span { color: rgba(255,255,255,0.85); font-size: 0.9rem; }

        .turma-gallery {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin: 3rem 0;
        }
        .turma-card {
            background: var(--bg-card);
            border: 1px solid var(--border-card);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            transition: border-color 0.2s, box-shadow 0.2s;
            position: relative;
        }
        .turma-card:hover {
            border-color: var(--border-hover);
            box-shadow: var(--shadow-md);
        }
        .turma-image img { width: 100%; height: 200px; object-fit: cover; }
        .turma-info { padding: 1.25rem; text-align: center; }
        .turma-info i { color: var(--brand-green-mid); font-size: 1.5rem; margin-bottom: 0.5rem; display: block; }
        .turma-info h4 { color: var(--text-200); font-size: 0.95rem; margin-bottom: 0.25rem; }
        .turma-info p { color: var(--text-600); font-size: 0.83rem; }
        .turma-card::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(161,188,33,0.06), transparent);
            transition: left 0.5s;
        }
        .turma-card:hover::before { left: 100%; }
        .turma-stats {
            display: flex; justify-content: center;
            gap: 4rem; margin-top: 3rem; flex-wrap: wrap;
        }
        .stat-item { text-align: center; }
        .stat-number {
            display: block;
            font-family: var(--font-mono);
            font-size: 3rem; font-weight: 700;
            color: var(--brand-green-mid);
        }
        .stat-label { color: var(--text-600); font-size: 0.9rem; }

        /* ── FOOTER ── */
        .footer {
            background: var(--brand-green-dark);
            border-top: 1px solid rgba(161,188,33,0.2);
            padding: 4rem 2rem 2rem;
            position: relative; z-index: 1;
        }
        .footer-content {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            gap: 3rem;
            max-width: 1200px;
            margin: 0 auto;
        }
        .footer-logo .navbar-brand-text { color: #ffffff; }
        .footer-logo img { height: 50px; margin-bottom: 0.5rem; }
        .footer-logo p { color: rgba(255,255,255,0.55); font-size: 0.9rem; margin-top: 0.75rem; }
        .footer-info h4, .footer-links h4 {
            color: var(--brand-lime);
            font-size: 0.95rem;
            margin-bottom: 1.25rem;
            font-family: var(--font-mono);
            letter-spacing: 0.08em;
        }
        .footer-info ul, .footer-links ul { list-style: none; }
        .footer-info li, .footer-links li { margin-bottom: 0.6rem; }
        .footer-info a, .footer-links a {
            color: rgba(255,255,255,0.5);
            text-decoration: none;
            transition: color 0.2s;
        }
        .footer-info a:hover, .footer-links a:hover { color: var(--brand-lime); }
        .footer-bottom {
            text-align: center;
            padding-top: 2rem; margin-top: 3rem;
            border-top: 1px solid rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.35);
            font-size: 0.8rem;
            max-width: 1200px; margin-left: auto; margin-right: auto;
        }

        /* ── WHATSAPP ── */
        .whatsapp-float {
            position: fixed; bottom: 2rem; right: 2rem;
            background: #25d366;
            color: white;
            width: 56px; height: 56px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem;
            text-decoration: none;
            box-shadow: 0 4px 20px rgba(37,211,102,0.4);
            transition: transform 0.3s, box-shadow 0.3s;
            z-index: 1000;
        }
        .whatsapp-float:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 24px rgba(37,211,102,0.55);
        }

        /* ── ANIMAÇÃO ── */
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── RESPONSIVO ── */
        @@media (max-width: 1024px) {
            .missao-grid, .equipe-grid { grid-template-columns: repeat(3, 1fr); }
            .conteudo-grid { grid-template-columns: repeat(2, 1fr); }
        }
        @@media (max-width: 768px) {
            .menu-toggle { display: block; }
            .nav-links {
                position: fixed; top: 72px; left: 0; right: 0;
                background: var(--brand-green-dark);
                flex-direction: column; padding: 1.5rem;
                gap: 1rem;
                transform: translateY(-150%);
                transition: transform 0.3s;
                border-bottom: 1px solid rgba(161,188,33,0.2);
            }
            .nav-links.active { transform: translateY(0); }
            .hero h1 { font-size: 2.5rem; }
            .hero-btns { flex-direction: column; align-items: center; }
            .sobre-content, .participar-content { grid-template-columns: 1fr; }
            .missao-grid, .conteudo-grid, .turma-gallery,
            .parceiros-content, .equipe-grid { grid-template-columns: 1fr; }
            .bc-quickstats { grid-template-columns: repeat(2, 1fr); }
            .aluno-recursos { grid-template-columns: repeat(2, 1fr); }
            .footer-content { grid-template-columns: 1fr; }
            .turma-stats { gap: 2rem; }
        }

        .hero-wave {
            border: solid 1px blue;
            width: 25%;
            background-color: red;            
            border-radius: 50% 40% 50% 20%;
        }
    </style>
</head>
